{% assign id = trmnl.plugin_settings.custom_fields_values.item_id %}

<div class="layout layout--col stretch-y">
  <div class="grid grid--cols-2 lg:portrait:grid--cols-1 gap--small lg:gap--large">
    
    <div class="item border--0">
      <div class="meta"></div>
      <div class="content flex--row gap--small">
        <span class="label lg:label--large">High:</span>
        <span class="value value--xxsmall lg:value--xsmall">{{ IDX_1.data[id].high | number_with_delimiter }}</span>
      </div>
    </div>

    <div class="item border--0">
      <div class="meta"></div>
      <div class="content flex--row gap--small">
        <span class="label lg:label--large">Low:</span>
        <span class="value value--xxsmall lg:value--xsmall lg:portrait:value--small">{{ IDX_1.data[id].low | number_with_delimiter }}</span>
      </div>
    </div>

    <div class="item border--0">
      <div class="meta"></div>
      <div class="content flex--row gap--small">
        <span class="label lg:label--large">30D:</span>
        <span class="value value--xxsmall lg:value--xxxsmall lg:portrait:value--xsmall">{{ IDX_0.item.day30.change }}</span>
      </div>
    </div>

    <div class="item border--0">
      <div class="meta"></div>
      <div class="content flex--row gap--small">
        <span class="label lg:label--large">90D:</span>
        <span class="value value--xxsmall lg:value--xxxsmall lg:portrait:value--xsmall">{{ IDX_0.item.day90.change }}</span>
      </div>
    </div>

    <div class="item border--0">
      <div class="meta"></div>
      <div class="content flex--row gap--small">
        <span class="label lg:label--large">180D:</span>
        <span class="value value--xxsmall lg:value--xxxsmall lg:portrait:value--xsmall">{{ IDX_0.item.day180.change }}</span>
      </div>
    </div>

    <div class="item border--0">
      <div class="meta"></div>
      <div class="content flex--row gap--small">
        <span class="label lg:label--large">Price:</span>
        <span class="value value--xxsmall lg:value--xxxsmall lg:portrait:value--xsmall">{{ IDX_0.item.today.price }}</span>
      </div>
    </div>
    
  </div>
</div>

<div class="title_bar">
  <img class="image" src="{{ IDX_0.item.icon }}">
  <span class="title">GE: {{ IDX_0.item.name }}</span>
</div>
