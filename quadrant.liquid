{% assign id = trmnl.plugin_settings.custom_fields_values.item_id %}

<div class="layout layout--col gap--space-between">
  <div class="grid grid--cols-2">
    
    <div class="item border--0">
      <div class="meta"></div>
      <div class="content flex--row gap--small">
        <span class="label">High:</span>
        <span class="value" style="font-size: 13px;">{{ IDX_1.data[id].high | number_with_delimiter }}</span>
      </div>
    </div>

    <div class="item border--0">
      <div class="meta"></div>
      <div class="content flex--row gap--small">
        <span class="label">Low:</span>
        <span class="value" style="font-size: 13px;">{{ IDX_1.data[id].low | number_with_delimiter }}</span>
      </div>
    </div>

    <div class="item border--0">
      <div class="meta"></div>
      <div class="content flex--row gap--small">
        <span class="label">30D:</span>
        <span class="value" style="font-size: 13px;">{{ IDX_0.item.day30.change }}</span>
      </div>
    </div>

    <div class="item border--0">
      <div class="meta"></div>
      <div class="content flex--row gap--small">
        <span class="label">90D:</span>
        <span class="value" style="font-size: 13px;">{{ IDX_0.item.day90.change }}</span>
      </div>
    </div>

    <div class="item border--0">
      <div class="meta"></div>
      <div class="content flex--row gap--small">
        <span class="label">180D:</span>
        <span class="value" style="font-size: 13px;">{{ IDX_0.item.day180.change }}</span>
      </div>
    </div>

    <div class="item border--0">
      <div class="meta"></div>
      <div class="content flex--row gap--small">
        <span class="label">Price:</span>
        <span class="value" style="font-size: 13px;">{{ IDX_0.item.today.price }}</span>
      </div>
    </div>
    
  </div>
</div>

<div class="title_bar">
  <img class="image" src="{{ IDX_0.item.icon }}">
  <span class="title">GE: {{ IDX_0.item.name }}</span>
</div>